# Base de données PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/trybe"

# JWT
JWT_SECRET="votre_secret_jwt_tres_long_et_securise"
JWT_EXPIRES_IN="7d"

# OpenAI
OPENAI_API_KEY="sk-..."

# Email (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="votre@email.com"
SMTP_PASS="votre_app_password"
EMAIL_FROM="TRYBE <noreply@trybe.app>"

# Serveur
PORT=3000
NODE_ENV=development

# Seuil de notification (score >= ce seuil = email)
NOTIFICATION_THRESHOLD=60
